{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "adminRole": { "type": "string" },
        "adminName": { "type": "string" },
        "walletBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "Internal administration staff account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "countryCode": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string" },
        "isActive": { "type": "boolean" },
        "permissions": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stockCount": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "inStock": { "type": "boolean" }
      },
      "required": ["name", "price", "stockCount"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "subtotal": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount voucher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "type": { "type": "string" },
        "expiryDate": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "discount"]
    },
    "Settings": {
      "title": "Settings",
      "description": "System configuration documents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "data": { "type": "object" }
      }
    },
    "Counter": {
      "title": "Counter",
      "description": "Global atomic sequence counter",
      "type": "object",
      "properties": {
        "orderCounter": { "type": "number", "description": "The sequential index for orders" }
      },
      "required": ["orderCounter"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Core user accounts"
    },
    "/admin_users/{adminId}": {
      "schema": "AdminUser",
      "description": "Staff and staff permissions"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store inventory"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer transactions"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Promotional discounts"
    },
    "/settings/counters": {
      "schema": "Counter",
      "description": "Global order ID counter"
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Site-wide configuration"
    },
    "/activityLogs/{logId}": {
      "schema": { "type": "object" },
      "description": "Administrative activity tracking"
    }
  }
}
